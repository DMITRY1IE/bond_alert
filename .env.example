# Обязательно
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgres://bond_user:bond_pass@localhost:5432/bond_bot?sslmode=disable

# Список разрешённых Telegram user ID через запятую (пусто = доступ всем)
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Сентимент только через OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=inclusionai/ling-2.6-flash:free

# Опционально: webhook вместо long polling (URL вашего сервера + путь /telegram/webhook)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

TELEGRAM_HTTP_TIMEOUT_SEC=60
TELEGRAM_GET_UPDATES_TIMEOUT=60

PARSING_INTERVAL_MINUTES=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

LISTEN_ADDR=:8000
LOG_LEVEL=INFO
